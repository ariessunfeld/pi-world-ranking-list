---
import Layout from "../../../components/Layout.astro";
import Breadcrumbs from "../../../components/Breadcrumbs.astro";
import GroupedRankingTable from "../../../components/GroupedRankingTable.astro";
import { loadRecords } from "../../../lib/data";
import { filterRecords, groupRankedRecords } from "../../../lib/rankings";

const records = filterRecords(loadRecords(), "pi");
const groups = groupRankedRecords(records, "country");
---

<Layout title="Pi Country Rankings" description="Pi rankings grouped by country." path="/pi/countries/">
  <Breadcrumbs items={[{ label: "Lists", href: "/lists/" }, { label: "Pi", href: "/pi/" }, { label: "Countries" }]} />
  <section class="content container">
    <h1>Pi Country Rankings</h1>
    <p class="lead">Country rankings are generated from the same canonical Pi records.</p>
    <GroupedRankingTable groups={groups} caption="Pi country ranking" />
  </section>
</Layout>
