---
import Layout from "../../../components/Layout.astro";
import Breadcrumbs from "../../../components/Breadcrumbs.astro";
import RankingTable from "../../../components/RankingTable.astro";
import { loadRecords } from "../../../lib/data";
import { filterRecords, rankRecords } from "../../../lib/rankings";

const records = filterRecords(loadRecords(), "pi", { juggling: true });
const ranked = rankRecords(records);
---

<Layout title="Pi and Juggling Ranking" description="Pi memorization records performed while juggling." path="/pi/juggling/">
  <Breadcrumbs items={[{ label: "Lists", href: "/lists/" }, { label: "Pi", href: "/pi/" }, { label: "Juggling" }]} />
  <section class="content container">
    <h1>Pi and Juggling Ranking</h1>
    <p class="lead">Public Pi records marked as juggling performances on the archived site.</p>
    <RankingTable records={ranked} caption="Pi and juggling ranking" tableId="pi-juggling-ranking" />
  </section>
</Layout>
