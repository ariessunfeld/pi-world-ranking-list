---
import Layout from "../../../components/Layout.astro";
import Breadcrumbs from "../../../components/Breadcrumbs.astro";
import RankingTable from "../../../components/RankingTable.astro";
import { loadRecords } from "../../../lib/data";
import { filterRecords, rankRecords } from "../../../lib/rankings";

const records = filterRecords(loadRecords(), "sqrt2", { juggling: true });
const ranked = rankRecords(records);
---

<Layout
  title="Square Root of 2 and Juggling Ranking"
  description="Square root of 2 memorization records performed while juggling."
  path="/sqrt2/juggling/"
>
  <Breadcrumbs items={[{ label: "Lists", href: "/lists/" }, { label: "sqrt(2)", href: "/sqrt2/" }, { label: "Juggling" }]} />
  <section class="content container">
    <h1>Square Root of 2 and Juggling Ranking</h1>
    <p class="lead">Public square root of 2 records marked as juggling performances on the archived site.</p>
    <RankingTable records={ranked} caption="sqrt(2) and juggling ranking" tableId="sqrt2-juggling-ranking" />
  </section>
</Layout>
