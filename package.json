{
  "name": "pi-world-ranking-list",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "ASTRO_TELEMETRY_DISABLED=1 astro dev",
    "build": "npm run validate:data && ASTRO_TELEMETRY_DISABLED=1 astro build",
    "preview": "ASTRO_TELEMETRY_DISABLED=1 astro preview",
    "test": "vitest run",
    "lint": "ASTRO_TELEMETRY_DISABLED=1 astro check",
    "format": "prettier --write .",
    "import": "tsx scripts/import-current-site.ts",
    "validate:data": "tsx scripts/validate-data.ts",
    "check:parity": "tsx scripts/check-import-parity.ts"
  },
  "dependencies": {
    "@astrojs/sitemap": "^3.2.1",
    "astro": "^5.0.0",
    "cheerio": "^1.0.0",
    "csv-parse": "^5.5.6",
    "csv-stringify": "^6.5.2",
    "js-yaml": "^4.1.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.4",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.10.2",
    "prettier": "^3.4.2",
    "prettier-plugin-astro": "^0.14.1",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
